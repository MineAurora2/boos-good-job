# 复制此文件为 .env，填入你自己的大模型接口信息。
# .env 是多个大模型接口的唯一存储位置，请勿提交真实 API Key。
# 也可以直接在网页面板「系统管理 → 接口管理」里增删改，保存后自动写回这里。

# 调度策略：failover 故障转移（默认，固定用第一个可用接口，熔断后才切换）
#           round_robin 轮询（每次请求轮转到下一个可用接口）
GOODJOB_LLM_STRATEGY=failover

# AI 二次筛选开关（岗位评分之外，再用大模型判断是否适合投递）
GOODJOB_LLM_JOB_FILTER=false

# 全局请求超时（秒）
GOODJOB_LLM_TIMEOUT=180

# 接口 1（编号从 1 开始，最多 20 个）。ENABLED=true 时地址、模型、Key 必须填全。
GOODJOB_LLM_1_NAME=示例接口
GOODJOB_LLM_1_API_BASE=https://api.example.com/v1
GOODJOB_LLM_1_API_KEY=
GOODJOB_LLM_1_MODEL=gpt-4o-mini
GOODJOB_LLM_1_ENABLED=false

# 再加接口就复制上面五行，把编号换成 2、3 …
# GOODJOB_LLM_2_NAME=备用接口
# GOODJOB_LLM_2_API_BASE=https://api.another.com/v1
# GOODJOB_LLM_2_API_KEY=
# GOODJOB_LLM_2_MODEL=deepseek-chat
# GOODJOB_LLM_2_ENABLED=false
