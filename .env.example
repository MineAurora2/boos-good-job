# 复制此文件为 .env，填入你自己的大模型接口信息。
# .env 是多个大模型接口的唯一存储位置，请勿提交真实 API Key 或代理凭据。
# 也可以直接在网页面板「系统管理 → 接口管理」里增删改，保存后自动写回这里。

# ===== 全局 LLM 行为 =====
# 调度策略：failover 故障转移（默认，固定用第一个可用接口，熔断后才切换）
#           round_robin 轮询（每次请求轮转到下一个可用接口）
GOODJOB_LLM_STRATEGY=failover

# AI 二次筛选开关（岗位评分之外，再用大模型判断是否适合投递）
GOODJOB_LLM_JOB_FILTER=false

# 全局请求超时（秒）；所有接口共用，网络较慢或模型推理较慢时可适当调大。
GOODJOB_LLM_TIMEOUT=180

# ===== 接口 1 =====
# 接口编号从 1 开始且必须连续，最多 20 个；网页管理器会按编号显示和调度。
# NAME 仅用于网页识别；API_BASE 通常以 /v1 结尾；MODEL 填服务商实际支持的模型 ID。
# ENABLED=true 时 API_BASE、API_KEY、MODEL 必须填全；false 可保留为尚未启用的草稿。
GOODJOB_LLM_1_NAME=示例接口
GOODJOB_LLM_1_API_BASE=https://api.example.com/v1
GOODJOB_LLM_1_API_KEY=
GOODJOB_LLM_1_MODEL=gpt-4o-mini

# 代理按接口独立设置，仅支持 http:// 或 https://；需要鉴权时可写为
# http://username:password@127.0.0.1:7890。网页回显时会自动隐藏凭据。
# PROXY_ENABLED=false 会强制该接口直连，不继承 HTTP_PROXY/HTTPS_PROXY 等系统变量。
GOODJOB_LLM_1_PROXY_URL=
GOODJOB_LLM_1_PROXY_ENABLED=false
GOODJOB_LLM_1_ENABLED=false

# ===== 更多接口 =====
# 增加接口时复制上面七个 GOODJOB_LLM_1_* 字段，并把编号依次改为 2、3……
# GOODJOB_LLM_2_NAME=备用接口
# GOODJOB_LLM_2_API_BASE=https://api.another.com/v1
# GOODJOB_LLM_2_API_KEY=
# GOODJOB_LLM_2_MODEL=deepseek-chat
# GOODJOB_LLM_2_PROXY_URL=http://127.0.0.1:7890
# GOODJOB_LLM_2_PROXY_ENABLED=true
# GOODJOB_LLM_2_ENABLED=false
# ===== Backend access security =====
# LAN, loopback, ULA, and link-local clients do not need a token. Public clients
# must use HTTPS and send this value as an Authorization: Bearer token (32-256 chars).
GOODJOB_SHARED_TOKEN=

# Optional comma-separated IP/CIDR list for reverse proxies you operate. A trusted
# proxy must overwrite both X-Forwarded-For and X-Forwarded-Proto on every request.
# Forwarding headers from an untrusted LAN peer are rejected; wildcards are rejected.
GOODJOB_TRUSTED_PROXIES=
